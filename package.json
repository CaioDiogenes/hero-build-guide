{
  "name": "hero-build-guide",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "validate:data": "node scripts/validate-heroes.mjs",
    "list:hero-routes": "node scripts/list-hero-routes.mjs",
    "migrate:heroes": "node scripts/migrate-heroes-to-firestore.mjs",
    "export:heroes": "node scripts/export-heroes-from-firestore.mjs",
    "sync:heroes": "npm run export:heroes && npm run validate:data",
    "editors": "node scripts/manage-editors.mjs",
    "format": "prettier --write \"src/**/*.{ts,html,scss}\" \"scripts/**/*.mjs\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss}\" \"scripts/**/*.mjs\""
  },
  "private": true,
  "packageManager": "npm@11.12.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/fire": "^21.0.0-rc.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "firebase": "^12.16.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.0",
    "angular-cli-ghpages": "^3.1.0",
    "firebase-admin": "^14.2.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
